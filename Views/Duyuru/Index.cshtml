@model List<ApartmanYonetimSistemi.Models.Duyuru>
@{ Layout = "_AdminLayout"; }

<style>
    .form-control-custom {
        width: 100%;
        padding: 10px 12px;
        margin-bottom: 12px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        font-size: 0.95rem;
        outline: none;
    }
    .form-control-custom:focus { border-color: #4f46e5; box-shadow: 0 0 0 2px rgba(79, 70, 229, 0.1); }
    
    .btn-submit {
        padding: 8px 20px;
        background: #4f46e5;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 500;
    }

    .clickable-title {
        color: #4f46e5;
        cursor: pointer;
        font-weight: 600;
    }
    .clickable-title:hover { text-decoration: underline; }
</style>

<div class="data-card" style="margin-bottom:20px; border-top: 4px solid #4f46e5;">
    <h5 style="margin-bottom:15px;"><i class="fas fa-plus-circle"></i> Yeni Duyuru Yaz</h5>
    <form asp-action="Ekle" method="post">
        <input type="text" name="Baslik" placeholder="Başlık" class="form-control-custom" required />
        <textarea name="Icerik" placeholder="Duyuru metni..." class="form-control-custom" rows="4" required></textarea>
        <button type="submit" class="btn-submit">Yayınla</button>
    </form>
</div>

<div class="data-card">
    <table class="custom-table" style="width:100%;">
        <thead>
            <tr style="text-align:left; border-bottom: 2px solid #f1f5f9;">
                <th>Başlık (Görmek için tıklayın)</th>
                <th>Tarih</th>
                <th style="text-align:right;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model) {
                <tr>
                    <td>
                        <span class="clickable-title" onclick="icerikGoster(this)" data-baslik="@d.Baslik" data-icerik="@d.Icerik">
                            @d.Baslik
                        </span>
                    </td>
                    <td>@d.YayinTarihi.ToShortDateString()</td>
                    <td style="text-align:right;">
                        <a href="/Duyuru/Guncelle/@d.Id" style="color:#f59e0b; margin-right:15px;"><i class="fas fa-edit"></i></a>
                        <button onclick="duyuruSilOnay(@d.Id)" style="background:none; border:none; color:#ef4444; cursor:pointer;"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function icerikGoster(element) {
        const baslik = element.getAttribute('data-baslik');
        const icerik = element.getAttribute('data-icerik');

        Swal.fire({
            title: '<strong>' + baslik + '</strong>',
            html: '<div style="text-align:left; padding:10px; line-height:1.5;">' + icerik + '</div>',
            icon: 'info',
            confirmButtonText: 'Tamam',
            confirmButtonColor: '#4f46e5'
        });
    }

    function duyuruSilOnay(id) {
        Swal.fire({
            title: 'Emin misiniz?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sil',
            cancelButtonText: 'Vazgeç'
        }).then((result) => { if (result.isConfirmed) window.location.href = "/Duyuru/Sil/" + id; });
    }
</script>