@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Hoş Geldiniz - AYS</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(rgba(10, 25, 47, 0.9), rgba(10, 25, 47, 0.9)), 
                        url('https://i.pinimg.com/1200x/3d/19/ed/3d19ed01ec5da5a7389cf96fd1d857ed.jpg');
            background-size: cover;
            background-position: center;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
            font-family: 'Poppins', sans-serif;
            color: white;
        }
        .selection-container {
            text-align: center;
            background: rgba(255, 255, 255, 0.05);
            padding: 50px;
            border-radius: 30px;
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            width: 600px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        }
        .cards-gap {
            display: flex;
            gap: 20px;
            margin-top: 40px;
        }
        .role-card {
            flex: 1;
            background: rgba(255, 255, 255, 0.07);
            padding: 40px 20px;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .role-card:hover {
            transform: translateY(-10px);
            background: rgba(56, 189, 248, 0.1);
            border-color: #38bdf8;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }
        .role-card i {
            font-size: 3.5rem;
            margin-bottom: 20px;
            display: block;
        }
        .role-card.admin i { 
            color: #38bdf8; 
            text-shadow: 0 0 15px rgba(56, 189, 248, 0.5);
        }
        .role-card.user i { 
            color: #4ade80; 
            text-shadow: 0 0 15px rgba(74, 222, 128, 0.5);
        }
        .role-card h3 { margin: 10px 0; font-size: 1.5rem; font-weight: 600; }
        .role-card p { font-size: 0.85rem; opacity: 0.7; margin: 0; line-height: 1.4; }
    </style>
</head>
<body>

    <div class="selection-container">
        <h1 style="font-size: 2.2rem; margin-bottom: 10px; font-weight: 600;">Apartman Yönetim Sistemi</h1>
        <p style="color: #94a3b8; font-weight: 300;">Lütfen devam etmek için giriş yetkinizi seçin</p>

        <div class="cards-gap">
            <a href="/Home/Index" class="role-card admin">
                <i class="fas fa-user-shield"></i>
                <h3>Yönetici</h3>
            </a>

            <a href="/Home/SakinGiris" class="role-card user">
                 <i class="fas fa-house-user"></i>
                   <h3>Apartman Sakini</h3>
            </a>
            </a>
        </div>
    </div>

</body>
</html>