@model List<ApartmanYonetimSistemi.Models.Duyuru>
@{
    Layout = "_SakinLayout";
}

<style>
    .duyuru-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .duyuru-box {
        background: white;
        border-radius: 15px;
        border: 1px solid #e2e8f0;
        padding: 20px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: 0.3s;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    }

        .duyuru-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 15px rgba(0,0,0,0.05);
            border-color: #4f46e5;
        }
</style>

<div style="background:white; padding:15px 25px; border-radius:12px; border:1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:15px;">
    <div style="display:flex; gap:10px; align-items:center;">
        <span style="font-size:0.85rem; font-weight:600; color:#64748b;">FİLTRE:</span>
        <select onchange="location.href='/SakinPanel/Duyurular?sure=' + this.value + '&sirala=@ViewBag.SeciliSirala'" style="padding:8px; border-radius:8px; border:1px solid #ddd; font-size:0.85rem; outline:none;">
            <option value="hepsi" selected="@(ViewBag.SeciliFiltre == "hepsi")">Tüm Zamanlar</option>
            <option value="son7" selected="@(ViewBag.SeciliFiltre == "son7")">Son 7 Gün</option>
            <option value="son30" selected="@(ViewBag.SeciliFiltre == "son30")">Son 30 Gün</option>
        </select>
    </div>

    <div style="display:flex; gap:10px; align-items:center;">
        <span style="font-size:0.85rem; font-weight:600; color:#64748b;">SIRALA:</span>
        <select onchange="location.href='/SakinPanel/Duyurular?sure=@ViewBag.SeciliFiltre&sirala=' + this.value" style="padding:8px; border-radius:8px; border:1px solid #ddd; font-size:0.85rem; outline:none;">
            <option value="yeni" selected="@(ViewBag.SeciliSirala == "yeni")">En Yeni</option>
            <option value="eski" selected="@(ViewBag.SeciliSirala == "eski")">En Eski</option>
            <option value="az" selected="@(ViewBag.SeciliSirala == "az")">A'dan Z'ye</option>
            <option value="za" selected="@(ViewBag.SeciliSirala == "za")">Z'den A'ya</option>
        </select>
    </div>
</div>

<div class="duyuru-grid">
    @foreach (var item in Model)
    {
        <div class="duyuru-box">
            <div>
                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                    <span style="background:#eef2ff; color:#4f46e5; padding:4px 10px; border-radius:6px; font-size:0.7rem; font-weight:700; text-transform:uppercase;">
                        DUYURU
                    </span>
                    <span style="color:#94a3b8; font-size:0.8rem;">
                        <i class="far fa-calendar-alt"></i> @item.YayinTarihi.ToString("dd.MM.yyyy")
                    </span>
                </div>
                <h5 style="color:#1e293b; font-size:1.1rem; font-weight:600; margin-bottom:10px;">@item.Baslik</h5>
                <p style="color:#64748b; font-size:0.9rem; line-height:1.5;">@item.Icerik</p>
            </div>
            <div style="margin-top:20px; padding-top:15px; border-top:1px solid #f1f5f9; text-align:right;">
                <small style="color:#94a3b8;">Yönetim Tarafından Yayınlandı</small>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div style="text-align:center; padding:100px; color:#94a3b8;">
        <i class="fas fa-search fa-3x" style="opacity:0.2;"></i>
        <p style="margin-top:15px;">Kriterlere uygun duyuru bulunamadı.</p>
    </div>
}