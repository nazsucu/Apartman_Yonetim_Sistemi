@model List<ApartmanYonetimSistemi.Models.Aidat>
@{
    Layout = "_SakinLayout";
}

<style>
    .aidat-table-row {
        border-bottom: 1px solid #f8fafc !important;
        transition: background-color 0.2s;
    }

        .aidat-table-row:hover {
            background-color: #f8fafc !important;
        }

    .btn-pay-now {
        background: #4f46e5;
        color: white !important;
        border: none;
        padding: 8px 16px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.8rem;
        text-decoration: none !important;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: background 0.2s, transform 0.1s;
    }

        .btn-pay-now:hover {
            background: #4338ca;
            transform: translateY(-1px);
        }
</style>

<div style="background:white; padding:30px; border-radius:15px; border:1px solid #e2e8f0; box-shadow:0 4px 6px rgba(0,0,0,0.02);">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:25px;">
        <h4 style="color:#1e293b; font-size:1.15rem; font-weight: 700; margin:0; display: flex; align-items: center; gap: 8px;">
            <i class="fas fa-file-invoice-dollar" style="color:#4f46e5;"></i> Aidat Ödeme Geçmişi
        </h4>
        <span style="font-size:0.8rem; color:#64748b; font-weight:600; background: #f1f5f9; padding: 4px 12px; border-radius: 20px;">TOPLAM KAYIT: @(Model?.Count ?? 0)</span>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background: #fee2e2; color: #991b1b; padding: 12px 15px; border-radius: 10px; margin-bottom: 20px; font-size: 0.9rem; border: 1px solid #f87171;">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background: #dcfce7; color: #16a34a; padding: 12px 15px; border-radius: 10px; margin-bottom: 20px; font-size: 0.9rem; border: 1px solid #10b981; font-weight: 600;">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div style="overflow-x:auto;">
        <table style="width:100%; border-collapse: collapse;">
            <thead>
                <tr style="text-align:left; color:#94a3b8; font-size:0.8rem; border-bottom: 2px solid #f1f5f9; text-transform: uppercase; letter-spacing: 0.5px;">
                    <th style="padding:15px 10px;">DÖNEM / AÇIKLAMA</th>
                    <th style="padding:15px 10px;">TUTAR</th>
                    <th style="padding:15px 10px;">KAYIT TARİHİ</th>
                    <th style="padding:15px 10px;">DURUM</th>
                    <th style="padding:15px 10px; text-align:right;">İŞLEM</th>
                </tr>
            </thead>
            <tbody style="color:#475569; font-size:0.9rem;">
                @if (Model != null && Model.Any())
                {
                    foreach (var a in Model)
                    {
                        <tr class="aidat-table-row">
                            <td style="padding:18px 10px;"><span style="font-weight: 600; color: #1e293b;">@a.Ay</span></td>
                            <td style="padding:18px 10px; font-weight:700; color:#1e293b;">₺@a.Tutar.ToString("N2")</td>
                            <td style="padding:18px 10px; color: #64748b;">@a.KayitTarihi.ToShortDateString()</td>
                            <td style="padding:18px 10px;">
                                @if (a.OdendiMi)
                                {
                                    <span style="background:#dcfce7; color:#16a34a; padding:5px 12px; border-radius:6px; font-size:0.75rem; font-weight:700; display: inline-flex; align-items: center; gap: 4px;">
                                        <i class="fas fa-check-circle"></i> ÖDENDİ
                                    </span>
                                }
                                else
                                {
                                    <span style="background:#fee2e2; color:#dc2626; padding:5px 12px; border-radius:6px; font-size:0.75rem; font-weight:700; display: inline-flex; align-items: center; gap: 4px;">
                                        <i class="fas fa-clock"></i> BEKLİYOR
                                    </span>
                                }
                            </td>
                            <td style="padding:18px 10px; text-align:right;">
                                @if (!a.OdendiMi)
                                {
                                    <a href="/SakinPanel/OdemeYap?aidatId=@a.Id" class="btn-pay-now">
                                        <i class="fas fa-credit-card"></i> Hemen Öde
                                    </a>
                                }
                                else
                                {
                                    <span style="color:#94a3b8; font-size:0.85rem; font-weight: 500; display: inline-flex; align-items: center; gap: 4px;">
                                        <i class="fas fa-check-circle" style="color: #10b981;"></i> Tamamlandı
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" style="text-align:center; padding:50px; color:#94a3b8;">
                            <i class="fas fa-info-circle fa-2x" style="display:block; margin-bottom:12px; color: #cbd5e1;"></i>
                            Henüz kayıtlı bir aidat veya borç kaydınız bulunmuyor.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div style="margin-top:20px; padding:15px 20px; background:#f0f7ff; border-radius:12px; border:1px solid #e0eefe; color:#0369a1; font-size:0.85rem; display: flex; align-items: center; gap: 10px; line-height: 1.5;">
    <i class="fas fa-info-circle" style="font-size: 1.1rem;"></i>
    <span><b>Güvenli Ödeme Notu:</b> "Hemen Öde" seçeneği ile kredi veya banka kartınızı kullanarak ödemelerinizi 256-bit SSL güvencesiyle anında gerçekleştirebilirsiniz.</span>
</div>