@using ApartmanYonetimSistemi.Data
@model List<ArizaTalebi>
@{
    Layout = "_SakinLayout";
}

<style>
    .ariza-table-row {
        border-bottom: 1px solid #f1f5f9 !important;
        transition: background-color 0.2s;
    }
    
        .ariza-table-row:hover {
            background-color: #fff1f2 !important;
        }

    .form-input-ariza {
        width: 100%;
        padding: 12px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        outline: none;
        font-family: inherit;
        font-size: 0.9rem;
        box-sizing: border-box;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .form-input-ariza:focus {
            border-color: #e11d48 !important;
            box-shadow: 0 0 0 3px rgba(225, 29, 72, 0.1) !important;
        }
</style>

<div class="data-card" style="background:white; padding:30px; border-radius:15px; border:1px solid #e2e8f0; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:25px;">
        <h4 style="color:#1e293b; font-size: 1.25rem; font-weight: 700; margin:0; display: flex; align-items: center; gap: 10px;">
            <i class="fas fa-tools" style="color:#e11d48;"></i> Teknik Arıza Bildirimlerim
        </h4>
        
        <button type="button" onclick="document.getElementById('arizaModal').style.display='flex'"
                style="background:#e11d48; color:white; border:none; padding:12px 24px; border-radius:10px; cursor:pointer; font-weight:600; font-size: 0.9rem; display:flex; align-items:center; gap:8px; transition: background 0.2s;">
            <i class="fas fa-plus"></i> Yeni Arıza Bildir
        </button>
    </div>

    <div style="overflow-x:auto;">
        <table style="width:100%; border-collapse:collapse;">
            <thead>
                <tr style="text-align:left; border-bottom:2px solid #f1f5f9; color:#64748b; font-size:0.85rem; letter-spacing: 0.5px;">
                    <th style="padding:15px 10px;">ARIZA BAŞLIĞI</th>
                    <th style="padding:15px 10px;">BİLDİRİM TARİHİ</th>
                    <th style="padding:15px 10px;">GÜNCEL DURUM</th>
                    <th style="padding:15px 10px; text-align: center;">İŞLEM</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr class="ariza-table-row">
                        <td style="padding:18px 10px; font-weight:500; color:#1e293b; font-size: 0.95rem;">@a.Baslik</td>
                        <td style="padding:18px 10px; color:#64748b; font-size: 0.9rem;">@a.Tarih.ToString("dd.MM.yyyy")</td>
                        <td style="padding:18px 10px;">
                            @if (a.Durum == "Tamamlandı")
                            {
                                <span style="color:#16a34a; background: #f0fdf4; padding: 6px 12px; border-radius: 8px; font-weight:600; font-size:0.85rem; display:inline-flex; align-items:center; gap:6px;">
                                    <i class="fas fa-check-circle"></i> @a.Durum
                                </span>
                            }
                            else
                            {
                                <span style="color:#d97706; background: #fffbeb; padding: 6px 12px; border-radius: 8px; font-weight:600; font-size:0.85rem; display:inline-flex; align-items:center; gap:6px;">
                                    <i class="fas fa-clock"></i> @a.Durum
                                </span>
                            }
                        </td>
                        <td style="padding:18px 10px; text-align: center;">
                            <button type="button" onclick="arizaDetayAc('@a.Baslik', '@a.Tarih.ToString("dd.MM.yyyy")', '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(a.Aciklama ?? "Açıklama bulunamadı."))')"
                                    style="background: #f1f5f9; color: #475569; border: none; padding: 6px 14px; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 0.8rem; transition: 0.2s;">
                                <i class="fas fa-eye"></i> İncele
                            </button>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" style="padding:40px; text-align:center; color:#94a3b8;">
                            <i class="fas fa-check-double" style="font-size: 2.5rem; color: #cbd5e1; display: block; margin-bottom: 12px;"></i>
                            Henüz aktif bir arıza bildiriminiz bulunmuyor.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="arizaModal" style="display:none; position:fixed; z-index:999999; left:0; top:0; width:100%; height:100%; background-color:rgba(15, 23, 42, 0.6); backdrop-filter: blur(3px); align-items:center; justify-content:center;">
    <div style="background-color:white; padding:30px; border-radius:16px; width:90%; max-width:500px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <h3 style="margin:0; color:#1e293b; font-size: 1.25rem; font-weight: 700;">Arıza Bildir</h3>
            <button type="button" onclick="document.getElementById('arizaModal').style.display='none'" style="background:none; border:none; font-size:1.5rem; cursor:pointer; color:#94a3b8; padding: 0; line-height: 1;">&times;</button>
        </div>
        <form asp-action="TalepKaydet" asp-controller="SakinPanel" method="post" style="display: flex; flex-direction: column; gap: 16px;">
            <input type="hidden" name="kategori" value="Arıza">
            <div>
                <label style="display:block; margin-bottom:6px; font-weight:600; color:#64748b; font-size:0.85rem;">Arıza Konusu</label>
                <input type="text" name="baslik" required placeholder="Örn: Asansör arızası, Koridor lambası patlak" class="form-input-ariza">
            </div>
            <div>
                <label style="display:block; margin-bottom:6px; font-weight:600; color:#64748b; font-size:0.85rem;">Detaylı Açıklama</label>
                <textarea name="aciklama" rows="4" required placeholder="Lütfen sorunu ve konumunu detaylıca açıklayın..." class="form-input-ariza" style="resize:none; font-family: inherit;"></textarea>
            </div>
            <div style="display:flex; gap:12px; margin-top: 5px;">
                <button type="submit" style="flex:2; background:#e11d48; color:white; border:none; padding:12px; border-radius:10px; font-weight:600; font-size: 0.95rem; cursor:pointer;">Gönder</button>
                <button type="button" onclick="document.getElementById('arizaModal').style.display='none'" class="form-input-ariza" style="flex:1; background:#f1f5f9; color:#64748b; border:none; padding:12px; border-radius:10px; font-weight:600; cursor:pointer; text-align:center;">İptal</button>
            </div>
        </form>
    </div>
</div>

<div id="detayModal" style="display:none; position:fixed; z-index:999999; left:0; top:0; width:100%; height:100%; background-color:rgba(15, 23, 42, 0.6); backdrop-filter: blur(3px); align-items:center; justify-content:center;">
    <div style="background-color:white; padding:30px; border-radius:16px; width:90%; max-width:480px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
        <div style="border-bottom: 1px solid #f1f5f9; padding-bottom: 12px; margin-bottom: 15px;">
            <h4 id="detayBaslik" style="margin:0; color:#1e293b; font-size: 1.2rem; font-weight: 700;">Arıza Detayı</h4>
            <span id="detayTarih" style="font-size: 0.8rem; color: #94a3b8; display: block; margin-top: 4px;"></span>
        </div>
        
        <div style="background: #f8fafc; padding: 15px; border-radius: 10px; border: 1px solid #e2e8f0; margin-bottom: 20px;">
            <span style="font-size: 0.75rem; color: #e11d48; font-weight: 700; display:block; margin-bottom: 6px; letter-spacing: 0.5px;">BİLDİRDİĞİNİZ MESAJINIZ:</span>
            <p id="detayMesaj" style="margin: 0; color: #334155; font-size: 0.95rem; white-space: pre-line; word-break: break-word; line-height: 1.5;"></p>
        </div>

        <button type="button" onclick="document.getElementById('detayModal').style.display='none'"
                style="width:100%; background:#f1f5f9; color:#475569; border:none; padding:12px; border-radius:10px; font-weight:600; cursor:pointer; font-size: 0.95rem;">
            Kapat
        </button>
    </div>
</div>

<script>
    function arizaDetayAc(baslik, tarih, mesaj) {
        document.getElementById('detayBaslik').innerText = baslik;
        document.getElementById('detayTarih').innerText = "Bildirim Tarihi: " + tarih;
        document.getElementById('detayMesaj').innerText = mesaj;
        document.getElementById('detayModal').style.display = 'flex';
    }

    window.onclick = function(event) {
        var arizaModal = document.getElementById('arizaModal');
        var detayModal = document.getElementById('detayModal');
        
        if (event.target == arizaModal) {
            arizaModal.style.display = "none";
        }
        if (event.target == detayModal) {
            detayModal.style.display = "none";
        }
    }
</script>