@using ApartmanYonetimSistemi.Models
@model List<Sakin>
@{
    Layout = "_AdminLayout";
}

<style>
    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        gap: 12px;
    }
    
    .search-box {
        flex-grow: 1;
        max-width: 320px;
    }
    .search-input-embedded {
        width: 100% !important;
        height: 38px !important;
        padding: 0 38px 0 15px !important; 
        border-radius: 8px !important;
        border: 1px solid #ddd !important;
        background: white url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="%2394a3b8" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>') no-repeat calc(100% - 12px) center !important;
        outline: none !important;
        font-family: inherit !important;
        font-size: 0.9rem !important;
        box-sizing: border-box !important;
        margin: 0 !important;
        line-height: normal !important;
    }
    
        .search-input-embedded:focus {
            border-color: #4f46e5 !important;
        }

    .select-sort {
        height: 38px !important;
        padding: 0 12px !important;
        border-radius: 8px !important;
        border: 1px solid #ddd !important;
        background: white !important;
        font-family: inherit !important;
        font-size: 0.9rem !important;
        outline: none !important;
    }

    .btn-add {
        background: #4f46e5;
        color: white;
        height: 38px;
        padding: 0 20px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
    }
    
    .form-input {
        width: 100%;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 8px;
        margin-bottom: 12px;
        box-sizing: border-box;
    }
</style>

@if (TempData["Mesaj"] != null)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
        Swal.fire({
        title: 'İşlem Başarılı',
        text: '@Html.Raw(TempData["Mesaj"])',
        icon: 'success',
        confirmButtonColor: '#4f46e5'
        });
        });
    </script>
}

<div class="action-bar">
    <form asp-action="Index" method="get" class="search-box">

        <input type="text" name="arama" value="@ViewBag.Arama" placeholder="Ara..." class="search-input-embedded">
    </form>
    
    <select onchange="location.href='?sirala=' + this.value" class="select-sort">
        <option value="ad_asc">Sırala: Ad (A-Z)</option>
        <option value="daire">Sırala: Daire No</option>
    </select>

    <button onclick="document.getElementById('ekleModal').style.display='block'" class="btn-add">
        <i class="fas fa-plus"></i> Yeni Kayıt
    </button>
</div>

<div style="background:white; padding:20px; border-radius:12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <table style="width:100%; border-collapse: collapse;">
        <thead>
            <tr style="text-align:left; color: #64748b; border-bottom: 2px solid #f1f5f9; font-size: 0.9rem;">
                <th style="padding:15px;">Daire</th>
                <th style="padding:15px;">Ad Soyad</th>
                <th style="padding:15px;">Kullanıcı Bilgileri</th>
                <th style="padding:15px; text-align:right;">İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr style="border-bottom: 1px solid #f8fafc;">
                    <td style="padding:15px;"><span style="background:#eef2ff; color:#4f46e5; padding:5px 12px; border-radius:6px; font-weight:600;">@s.DaireNo</span></td>
                    <td style="padding:15px; font-weight:500;">@s.AdSoyad</td>
                    <td style="padding:15px; font-size:0.85rem; color:#64748b; line-height: 1.5;">
                        <b>Kullanıcı:</b> @s.KullaniciAdi <br />
                        <b>E-posta:</b> @s.Email
                    </td>
                    <td style="padding:15px; text-align:right;">
                        <a href="javascript:void(0)" onclick="silOnay(@s.Id)" style="color:#ef4444; font-size: 1.1rem; padding: 5px;"><i class="fas fa-trash-alt"></i></a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" style="padding: 30px; text-align: center; color: #94a3b8;">Aranan kriterlere uygun sakin bulunamadı.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="ekleModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(15, 23, 42, 0.6); z-index:999; backdrop-filter: blur(3px); align-items: center; justify-content: center;">
    <div style="background:white; width:400px; padding:30px; border-radius:16px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); margin: 100px auto;">
        <h3 style="margin-top:0; margin-bottom:20px; color:#1e293b;">Sakin Ekle</h3>
        <form asp-action="Ekle" method="post">
            <input type="text" name="AdSoyad" placeholder="Ad Soyad" class="form-input" required>
            <input type="number" name="DaireNo" placeholder="Daire No" class="form-input" required>
            <input type="email" name="Email" placeholder="E-posta" class="form-input" required>
            <input type="text" name="Telefon" placeholder="Telefon (Opsiyonel)" class="form-input">
            <div style="display:flex; gap:10px; margin-top: 5px;">
                <button type="submit" class="btn-add" style="flex:1; justify-content:center;">Kaydet</button>
                <button type="button" onclick="document.getElementById('ekleModal').style.display='none'" style="flex:1; background:#f1f5f9; border:none; border-radius:8px; color:#475569; font-weight: 500; cursor:pointer;">Vazgeç</button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function silOnay(id) {
    Swal.fire({
    title: 'Emin misiniz?',
    text: "Bu sakini silerseniz ona ait tüm aidat kayıtları da silinecektir!",
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#ef4444',
    cancelButtonColor: '#94a3b8',
    confirmButtonText: 'Evet, Sil!',
    cancelButtonText: 'Vazgeç',
    background: '#ffffff'
    }).then((result) => {
    if (result.isConfirmed) {
    window.location.href = "/Sakin/Sil?id=" + id;
    }
    });
    }

    window.onclick = function(event) {
    var modal = document.getElementById('ekleModal');
    if (event.target == modal) {
    modal.style.display = "none";
    }
    }
</script>