@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor httpContextAccessor
@{
    var currentUrl = ViewContext.HttpContext.Request.Path.ToString().ToLower();
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Sakin Paneli</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --admin-bg: #1e293b; --admin-primary: #4f46e5; }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        body { background-color: #f1f5f9; }

        .sidebar { width: 260px; background: var(--admin-bg); color: white; position: fixed; height: 100vh; padding: 20px; z-index: 1000; }
        .logo { font-size: 1.3rem; font-weight: 700; color: #4ade80; margin-bottom: 30px; display: flex; align-items: center; gap: 10px; }
        .nav-item { display: flex; align-items: center; gap: 12px; padding: 12px; color: #94a3b8; text-decoration: none; border-radius: 8px; margin-bottom: 5px; transition: 0.3s; }
        .nav-item:hover, .nav-item.active { background: #334155; color: white; }
        .nav-item.active { border-left: 4px solid #4ade80; }

        .main-content { margin-left: 260px; width: calc(100% - 260px); min-height: 100vh; }
        
        .top-bar { height: 70px; background: white; display: flex; align-items: center; justify-content: space-between; padding: 0 30px; border-bottom: 1px solid #e2e8f0; }
        .header-right { display: flex; align-items: center; gap: 20px; }

        .content-area { padding: 30px; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 30px; }
        
        .stat-card { 
            background: white !important; 
            padding: 25px; 
            border-radius: 15px; 
            display: flex; 
            align-items: center; 
            gap: 20px; 
            border: 1px solid #e2e8f0; 
            box-shadow: 0 4px 6px rgba(0,0,0,0.05); 
        }
        
        .stat-icon { 
            width: 60px; height: 60px; border-radius: 12px; 
            display: flex; align-items: center; justify-content: center; 
            font-size: 1.5rem; flex-shrink: 0;
        }

        .stat-info span { color: #64748b; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; }
        .stat-info h3 { margin-top: 5px; font-size: 1.6rem; font-weight: 700; color: #1e293b; }

        .data-card { background: white; padding: 25px; border-radius: 15px; border: 1px solid #e2e8f0; }
        .duyuru-item { padding: 15px 0; border-bottom: 1px solid #f1f5f9; }
        .duyuru-item:last-child { border-bottom: none; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="logo"><i class="fas fa-building"></i> <span>Sakin Paneli</span></div>
        <nav>
            <a href="/SakinPanel/Dashboard" class="nav-item @(currentUrl.Contains("dashboard") ? "active" : "")"><i class="fas fa-home"></i> Ana Sayfa</a>
            <a href="/SakinPanel/Aidatlarim" class="nav-item @(currentUrl.Contains("aidatlarim") ? "active" : "")"><i class="fas fa-wallet"></i> Aidatlarım</a>
            <a href="/SakinPanel/Taleplerim" class="nav-item @(currentUrl.Contains("taleplerim") ? "active" : "")"><i class="fas fa-comment-dots"></i> Taleplerim</a>
            <a href="/SakinPanel/Arizalarim" class="nav-item @(currentUrl.Contains("arizalarim") ? "active" : "")"><i class="fas fa-tools"></i> Arıza Bildir</a>
            <a href="/SakinPanel/Duyurular" class="nav-item @(currentUrl.Contains("duyurular") ? "active" : "")"><i class="fas fa-bullhorn"></i> Tüm Duyurular</a>
            
            <a href="/SakinPanel/Ayarlar" class="nav-item @(currentUrl.Contains("ayarlar") ? "active" : "")"><i class="fas fa-cog"></i> Ayarlar</a>
            
            <a href="/Home/Welcome" class="nav-item" style="margin-top:20px; color:#f87171;"><i class="fas fa-sign-out-alt"></i> Çıkış Yap</a>
        </nav>
    </div>

    <div class="main-content">
        <header class="top-bar">
            <h3>Hoş Geldin, <span style="color:var(--admin-primary)">@(httpContextAccessor.HttpContext.Session.GetString("SakinAd") ?? "Sakin")</span> 👋</h3>
            <div class="header-right" style="display: flex; align-items: center; gap: 20px;">
                
                <div style="color: #64748b; font-size: 0.85rem; border-right: 1px solid #e2e8f0; padding-right: 15px; display: flex; align-items: center; gap: 8px;">
                    <i class="far fa-calendar-alt" style="color: #4f46e5;"></i> @DateTime.Now.ToString("dd MMMM yyyy")
                </div>
                
                <a href="/SakinPanel/Ayarlar" title="Hesap Ayarları" style="text-decoration: none; transition: 0.3s; line-height: 0;">
                    <img src="https://ui-avatars.com/api/?name=@(httpContextAccessor.HttpContext.Session.GetString("SakinAd") ?? "S")&background=4f46e5&color=fff" 
                         style="width: 40px; border-radius: 50%; border: 2px solid #eef2ff; transition: 0.3s;" 
                         onmouseover="this.style.borderColor='#4f46e5'; this.style.transform='scale(1.05)';" 
                         onmouseout="this.style.borderColor='#eef2ff'; this.style.transform='scale(1)';" 
                         alt="Profil">
                </a>
            </div>
        </header>
        <div class="content-area">
            @RenderBody()
        </div>
    </div>
</body>
</html>