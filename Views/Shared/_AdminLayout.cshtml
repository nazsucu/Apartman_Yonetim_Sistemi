@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var currentUrl = ViewContext.HttpContext.Request.Path.ToString().ToLower();
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Yönetim Paneli - AYS</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin-style.css">
</head>
<body>
    <div class="admin-wrapper">
        <aside class="sidebar">
            <div class="logo"><i class="fas fa-building"></i> <span>SiteYönetim</span></div>
            <nav id="admin-nav">
                <a href="/Admin/Dashboard" class="nav-item @(currentUrl.Contains("dashboard") || currentUrl == "/admin" ? "active" : "")">
                    <i class="fas fa-th-large"></i> Ana Sayfa
                </a>
                <a href="/Duyuru/Index" class="nav-item @(currentUrl.Contains("duyuru") ? "active" : "")">
                    <i class="fas fa-bullhorn"></i> Duyurular
                </a>
                <a href="/Aidat/Index" class="nav-item @(currentUrl.Contains("aidat") ? "active" : "")">
                    <i class="fas fa-wallet"></i> Aidatlar
                </a>
                <a href="/Harcama/Index" class="nav-item @(currentUrl.Contains("harcama") ? "active" : "")">
                    <i class="fas fa-money-bill-wave"></i> Harcamalar
                </a>
                <a href="/Admin/Arizalar" class="nav-item @(currentUrl.Contains("arizalar") ? "active" : "")">
                    <i class="fas fa-wrench"></i> Arızalar
                </a>
                <a href="/Sakin/Index" class="nav-item @(currentUrl.Contains("sakin") ? "active" : "")">
                    <i class="fas fa-users"></i> Sakinler
                </a>
                <a href="/Admin/Ayarlar" class="nav-item @(currentUrl.Contains("ayarlar") ? "active" : "")">
                    <i class="fas fa-cog"></i> Ayarlar
                </a>
    
                <a href="/Admin/CikisYap" class="nav-item logout-item" style="color: #f87171 !important; margin-top: auto; border-top: 1px solid #334155; padding-top: 20px;">
                    <i class="fas fa-sign-out-alt"></i> Çıkış Yap
                </a>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar" style="display: flex; justify-content: space-between; align-items: center; padding: 15px 30px;">
                <div class="header-left">
                    <h3 style="margin:0;">Hoş Geldiniz, <span style="color: #4f46e5;">@(HttpContextAccessor.HttpContext.Session.GetString("YoneticiAd") ?? "Yönetici")</span> 👋</h3>
                </div>
                <div class="header-right" style="display: flex; align-items: center; gap: 20px;">
                    <div class="date-info" style="color: #64748b; font-weight: 500;"><i class="far fa-calendar-alt"></i> @DateTime.Now.ToString("dd MMMM yyyy")</div>
                    <a href="/Admin/Ayarlar" class="profile">
                        <img src="https://ui-avatars.com/api/?name=@(HttpContextAccessor.HttpContext.Session.GetString("YoneticiAd") ?? "Admin")&background=4f46e5&color=fff" alt="avatar" style="width: 40px; border-radius: 50%;">
                    </a>
                </div>
            </header>
            <section class="content" style="padding: 30px;">
                @RenderBody()
            </section>
        </main>
    </div>
</body>
</html>